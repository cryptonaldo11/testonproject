# Environment Variables

# ==========================================
# API runtime (required in all environments)
# ==========================================

# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/teston_hr

# Secret used to sign JWTs
JWT_SECRET=change-this-to-a-long-random-secret

# API server port
# Optional in runtime code; defaults to 8080 if omitted
PORT=8080

# Node environment
NODE_ENV=development

# Optional API log level (defaults to info)
# LOG_LEVEL=info

# ==========================================
# Frontend development/build settings
# ==========================================

# Dev server port (optional; defaults to 5173)
# FRONTEND_PORT=5173

# Optional base path for Vite builds (defaults to /)
# BASE_PATH=/

# Development-only API proxy target for Vite dev server
# This does NOT change production runtime API calls in the built app
# API_URL=http://localhost:8080

# ==========================================
# API integration tests (dedicated test DB)
# ==========================================

# Copy to artifacts/api-server/.env.test before running:
# pnpm --filter @workspace/api-server run test:run
# TEST DATABASE MUST BE SEPARATE FROM YOUR DEV DB
# DATABASE_URL=postgresql://username:password@localhost:5432/teston_hr_test
# JWT_SECRET=test-only-secret

# ==========================================
# Object storage
# ==========================================

# The current object storage implementation still assumes a Replit sidecar
# flow in artifacts/api-server/src/lib/objectStorage.ts.
# These generic cloud values are not sufficient on their own unless storage
# wiring is updated.
# GOOGLE_CLOUD_PROJECT_ID=your-project-id
# GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket-name
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
